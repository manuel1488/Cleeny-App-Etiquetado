# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force LF for source files
*.cs    text eol=lf
*.razor text eol=lf
*.xaml  text eol=lf
*.xml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.csproj text eol=lf
*.slnx   text eol=lf
*.props  text eol=lf
*.targets text eol=lf

# Binary files — do not touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.ttf  binary
*.woff binary
*.woff2 binary
*.apk  binary
*.aab  binary
*.ipa  binary
*.pfx  binary
*.p12  binary
