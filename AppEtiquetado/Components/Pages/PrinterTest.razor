@page "/printer-test"
@layout BlankLayout
@inject IBrotherPrinterService? PrinterService
@inject ISnackbar Snackbar

<PageTitle>Test de impresora — AppEtiquetado</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-4" Style="min-height: 100vh; background: #F5F9F9;">

    <MudStack Spacing="4">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Print" Style="color: #1A6868; font-size: 2rem;" />
            <MudText Typo="Typo.h5"
                     Style="font-family: Poppins, sans-serif; font-weight: 600; color: #1A6868;">
                Test de impresora Brother
            </MudText>
        </MudStack>

        @if (PrinterService is null)
        {
            <MudAlert Severity="Severity.Warning">
                El servicio de impresión no está disponible en esta plataforma.
                Solo funciona en Android.
            </MudAlert>
        }
        else
        {
            @* ── Paso 1: Dispositivos emparejados ────────────────────────── *@
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" GutterBottom="true">
                    1. Seleccionar impresora
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                    Empareja la QL-1110NWB por Bluetooth en Ajustes de Android antes de continuar.
                </MudText>

                <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RefreshDevices"
                               Disabled="@_scanning">
                        Actualizar lista
                    </MudButton>
                    @if (_scanning)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    }
                </MudStack>

                @if (_devices.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        No hay dispositivos emparejados. Empareja la impresora en Ajustes → Bluetooth.
                    </MudAlert>
                }
                else
                {
                    <MudRadioGroup @bind-Value="_selectedAddress">
                        @foreach (var d in _devices)
                        {
                            <MudRadio Value="@d.Address" Color="Color.Primary">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1" Style="font-weight: 500;">@d.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@d.Address</MudText>
                                </MudStack>
                            </MudRadio>
                        }
                    </MudRadioGroup>
                }
            </MudPaper>

            @* ── Paso 2: Tamaño de etiqueta ──────────────────────────────── *@
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" GutterBottom="true">
                    2. Tamaño de etiqueta
                </MudText>

                <MudSelect @bind-Value="_labelSize"
                           Label="Cinta instalada"
                           Variant="Variant.Outlined"
                           Dense="true">
                    @foreach (var ls in _labelSizes)
                    {
                        <MudSelectItem Value="@ls.Key">@ls.Value</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>

            @* ── Paso 3: Imprimir ────────────────────────────────────────── *@
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" GutterBottom="true">
                    3. Imprimir prueba
                </MudText>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintTestAsync"
                           Disabled="@(string.IsNullOrEmpty(_selectedAddress) || _printing)">
                    @if (_printing)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Imprimiendo...</span>
                    }
                    else
                    {
                        <span>Imprimir etiqueta de prueba</span>
                    }
                </MudButton>
            </MudPaper>

            @* ── Log de resultado ────────────────────────────────────────── *@
            @if (!string.IsNullOrEmpty(_log))
            {
                <MudPaper Elevation="0" Class="pa-3 rounded"
                          Style="background: #1e1e1e; font-family: monospace;">
                    <MudText Typo="Typo.caption" Style="@_logStyle">
                        @_log
                    </MudText>
                </MudPaper>
            }
        }

    </MudStack>
</MudContainer>

@code {
    private List<PrinterDevice> _devices = [];
    private string _selectedAddress = string.Empty;
    private string _labelSize = "DieCutW62H100";
    private bool _scanning;
    private bool _printing;
    private string _log = string.Empty;
    private bool _lastSuccess;
    private string _logStyle => _lastSuccess
        ? "color: #4ec9b0; white-space: pre-wrap; word-break: break-all;"
        : "color: #f48771; white-space: pre-wrap; word-break: break-all;";

    // Tamaños comunes para QL-1110NWB — ajustar según cintas disponibles
    // Los nombres deben coincidir con los valores del enum QLPrintSettings.LabelSize
    // Claves = nombre de la propiedad estática en QLPrintSettings.LabelSize
    private static readonly Dictionary<string, string> _labelSizes = new()
    {
        ["DieCutW62H100"]  = "DK-11209  62×100 mm (die-cut)",
        ["RollW62"]        = "DK-22205  62 mm continuo",
        ["DieCutW103H164"] = "DK-11247  103×164 mm (die-cut)",
        ["DieCutW62H29"]   = "DK-11218  62×29 mm (retorno envío)",
        ["DieCutW62H60"]   = "DK-11221  62×60 mm (die-cut)",
        ["DieCutW102H152"] = "DK-11241  102×152 mm (die-cut)",
    };

    protected override void OnInitialized()
    {
        if (PrinterService is not null)
            _devices = PrinterService.GetPairedPrinters();
    }

    private void RefreshDevices()
    {
        if (PrinterService is null) return;
        _scanning = true;
        _devices = PrinterService.GetPairedPrinters();
        _scanning = false;
    }

    private async Task PrintTestAsync()
    {
        if (PrinterService is null || string.IsNullOrEmpty(_selectedAddress)) return;

        _printing = true;
        _log = string.Empty;
        try
        {
            var result = await PrinterService.PrintTestAsync(_selectedAddress, _labelSize);
            _lastSuccess = result.Success;
            _log = result.Message;

            Snackbar.Add(
                result.Success ? "Impresión exitosa" : $"Error: {result.Message}",
                result.Success ? Severity.Success : Severity.Error);
        }
        catch (Exception ex)
        {
            _lastSuccess = false;
            _log = $"Excepción: {ex.Message}";
            Snackbar.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _printing = false;
        }
    }
}
