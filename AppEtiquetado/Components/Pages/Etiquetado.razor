@page "/etiquetado"
@inject AuthService AuthService
@inject LabelService LabelService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IServiceProvider Services

<PageTitle>Etiquetado — @AppConfig.AppName</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-4">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">

            <MudPaper Elevation="2" Class="pa-5 rounded-lg">

                <MudText Typo="Typo.h5" GutterBottom="true"
                         Style="font-family: Poppins, sans-serif; font-weight: 600; color: #1A6868;">
                    Etiquetado a granel
                </MudText>
                <MudDivider Class="mb-5" />

                <MudStack Spacing="3">

                    <MudAutocomplete T="ProductDto"
                                     Label="Buscar producto"
                                     Value="_product"
                                     ValueChanged="OnProductChanged"
                                     SearchFunc="SearchAsync"
                                     ToStringFunc="@(p => p?.ToString() ?? string.Empty)"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     ResetValueOnEmptyText="true"
                                     Clearable="true"
                                     DebounceInterval="300"
                                     MinCharacters="2"
                                     Margin="Margin.Dense">
                        <NoItemsTemplate>
                            <MudText Class="px-4 py-1" Typo="Typo.body2">Sin resultados</MudText>
                        </NoItemsTemplate>
                    </MudAutocomplete>

                    @if (_product is not null)
                    {
                        <MudNumericField @bind-Value="_quantity"
                                         @ref="_quantityField"
                                         Label="Cantidad"
                                         Variant="Variant.Outlined"
                                         Min="0.001m"
                                         Step="0.100m"
                                         Format="0.###"
                                         Adornment="Adornment.End"
                                         AdornmentText="@_product.UnitMeasureCode"
                                         Margin="Margin.Dense" />

                        <MudTextField Value="@_product.Price.ToString("C2")"
                                      Label="Precio unitario"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      Margin="Margin.Dense" />

                        <MudPaper Elevation="0" Class="pa-3 rounded"
                                  Style="background-color: #e8f4f4;">
                            <MudStack Spacing="1">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Color="Color.Default">Subtotal</MudText>
                                    <MudText Typo="Typo.body2">@Subtotal.ToString("C2")</MudText>
                                </MudStack>
                                @if (_product.IsTaxable)
                                {
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2" Color="Color.Default">IVA (@((_product.TaxRate * 100).ToString("0.##"))%)</MudText>
                                        <MudText Typo="Typo.body2">@TaxAmount.ToString("C2")</MudText>
                                    </MudStack>
                                }
                                <MudDivider Class="my-1" />
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body1" Style="font-weight: 600;">Total</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Primary"
                                             Style="font-family: Poppins, sans-serif; font-weight: 700;">
                                        @Total.ToString("C2")
                                    </MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Print"
                                   OnClick="PrintAsync"
                                   Disabled="@(!CanPrint || _printing)">
                            @if (_printing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Generando...</span>
                            }
                            else
                            {
                                <span>Imprimir etiqueta</span>
                            }
                        </MudButton>

                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Size="Size.Large"
                                       OnClick="Reset"
                                       title="Limpiar formulario" />
                    </MudStack>

                </MudStack>
            </MudPaper>

        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private ProductDto? _product;
    private decimal _quantity;
    private bool _printing;
    private MudNumericField<decimal>? _quantityField;
    private IBrotherPrinterService? _printer;

    private decimal Subtotal => Math.Round((_product?.Price ?? 0m) * _quantity, 2);
    private decimal TaxAmount => Math.Round(Subtotal * (_product?.TaxRate ?? 0m), 2);
    private decimal Total => Subtotal + TaxAmount;
    private bool CanPrint => _product is not null && _quantity > 0 && Subtotal > 0;

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }
        _printer = Services.GetService<IBrotherPrinterService>();
    }

    private async Task OnProductChanged(ProductDto? product)
    {
        _product = product;
        _quantity = 0;
        if (product is not null && _quantityField is not null)
            await _quantityField.FocusAsync();
    }

    private async Task<IEnumerable<ProductDto>> SearchAsync(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2)
            return [];
        try
        {
            return await LabelService.SearchProductsAsync(value, ct);
        }
        catch (OperationCanceledException)
        {
            return [];
        }
        catch (UnauthorizedAccessException)
        {
            await HandleSessionExpiredAsync();
            return [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al buscar: {ex.Message}", Severity.Warning);
            return [];
        }
    }

    private async Task PrintAsync()
    {
        if (_product is null || _quantity <= 0) return;

        _printing = true;
        try
        {
            var dto = new CreateBulkLabelJobDto
            {
                ProductId = _product.Id,
                Quantity = _quantity,
                UnitMeasureCode = _product.UnitMeasureCode,
                UnitPrice = _product.Price,
                TotalPrice = Subtotal,
                LabelCount = 1,
            };

            var job = await LabelService.CreateLabelJobAsync(dto);

            if (_printer is null)
            {
                Snackbar.Add("No hay impresora disponible en esta plataforma.", Severity.Warning);
                return;
            }

            var address = Preferences.Get("printer_address", string.Empty);
            if (string.IsNullOrEmpty(address))
            {
                Snackbar.Add("No hay impresora configurada. Ve a Impresora.", Severity.Warning);
                return;
            }

            var labelSize   = Preferences.Get("label_size",      "DieCutW62H100");
            var labelHeight = Preferences.Get("label_height_mm", 50);
            var result = await _printer.PrintLabelAsync(job, address, labelSize, labelHeight);

            if (result.Success)
            {
                Snackbar.Add($"Impreso: {job.ProductName}", Severity.Success);
                Reset();
            }
            else
            {
                Snackbar.Add($"Error al imprimir: {result.Message}", Severity.Error);
            }
        }
        catch (UnauthorizedAccessException)
        {
            await HandleSessionExpiredAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al generar etiqueta: {ex.Message}", Severity.Error);
        }
        finally
        {
            _printing = false;
        }
    }

    private async Task HandleSessionExpiredAsync()
    {
        await AuthService.LogoutAsync();
        Snackbar.Add("Sesión expirada. Inicia sesión nuevamente.", Severity.Warning);
        Navigation.NavigateTo("/login", replace: true);
    }

    private void Reset()
    {
        _product = null;
        _quantity = 0;
    }
}
